{
  "name": "photon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Photon — a cosmic roguelike (TypeScript build)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "sync:standalone": "cp dist/index.html ../photon-racer-v2.html",
    "build:standalone": "npm run build && npm run sync:standalone",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "qa:fast": "npm test && npm run typecheck && npm run build",
    "precommit": "npm test && npm run typecheck && npm run build:standalone"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "three": "^0.160.0"
  }
}
